{
  "name": "swifthost",
  "version": "1.2.0",
  "description": "Expose local servers to the internet with advanced management dashboard",
  "main": "dist/sdk/deploy.js",
  "types": "dist/sdk/deploy.d.ts",
  "exports": {
    ".": {
      "import": "./dist/sdk/deploy.js",
      "require": "./dist/sdk/deploy.js",
      "types": "./dist/sdk/deploy.d.ts"
    },
    "./core/*": {
      "import": "./dist/core/*.js",
      "require": "./dist/core/*.js",
      "types": "./dist/core/*.d.ts"
    },
    "./utils/*": {
      "import": "./dist/utils/*.js",
      "require": "./dist/utils/*.js",
      "types": "./dist/utils/*.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "swf": "./bin/swf",
    "swifthost": "./bin/swf"
  },
  "files": [
    "dist/**/*",
    "bin/**/*"
  ],
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "mkdir -p dist/pages && cp -r src/pages/* dist/pages/ 2>/dev/null || true && mkdir -p dist/public && cp -r src/public/* dist/public/ 2>/dev/null || true",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": ["tunnel", "cloudflare", "localhost", "expose", "dashboard", "ngrok-alternative"],
  "license": "MIT",
  "author": "Alisson",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.13.6",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "cross-spawn": "^7.0.6",
    "date-fns": "^4.1.0",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "http-proxy-middleware": "^3.0.5",
    "node-fetch": "^3.3.2",
    "ora": "^9.3.0",
    "portfinder": "^1.0.38",
    "ts-node": "^10.9.2",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node-fetch": "^2.6.13",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
